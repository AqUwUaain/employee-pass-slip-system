<?xml version="1.0" encoding="UTF-8"?>

<!--
    System Module: Campus Monitoring & Security Lifecycle
    View Reference: PassSlip.fxml Pop-up Modal Document View
    Target Design Guide Compatibility: Dashboard.fxml Identity System
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="passSlipModalRoot" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="650.0" spacing="0.0" style="-fx-background-color: #252220; -fx-background-radius: 12px; -fx-border-color: #7C0A02; -fx-border-radius: 12px; -fx-border-width: 2px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.55), 20, 0, 0, 6);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PassSlipController">
    <children>

        <!-- MODAL HEADER BAR (Matches Institutional Dashboard Identity) -->
        <HBox alignment="CENTER_LEFT" prefHeight="55.0" style="-fx-background-color: #7C0A02; -fx-background-radius: 9px 9px 0 0; -fx-padding: 0 20px;">
            <children>
                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffe600;" text="🎫 SYSTEM PASS SLIP REGISTRY" />
                <StackPane HBox.hgrow="ALWAYS" />
                <!-- Tiny Top Close Window Control Switch -->
                <Button fx:id="btnTopClose" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-cursor: hand;" text="✕" />
            </children>
        </HBox>

        <!-- CORE CONTAINER WRAPPER -->
        <VBox spacing="12.0" style="-fx-padding: 20px 25px;">
            <children>

                <!-- INSTRUCTION BANNER -->
                <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: rgba(212,168,83,0.1); -fx-border-color: #D4A853; -fx-border-width: 1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 10px 14px;">
                    <children>
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #D4A853;" text="&#x2139;" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #D4A853; -fx-wrap-text: true;" text="Select an employee, enter the purpose, and choose an estimated return time. Fields marked with * are required." HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <!-- THE STRUCTURAL SLIP DOCUMENT CONTAINER LAYER -->
                <HBox style="-fx-border-color: #3D3229; -fx-border-width: 2px; -fx-background-color: #2D2520;">
                    <children>

                        <!-- VERTICAL LEFT BAR SIDE TITLE: PASS SLIP -->
                        <VBox alignment="CENTER" prefWidth="65.0" style="-fx-background-color: #2D2520; -fx-border-color: transparent #3D3229 transparent transparent; -fx-border-width: 0 2px 0 0; -fx-padding: 10px 0;">
                            <children>
                                <Label rotate="-90.0" style="-fx-font-family: 'Arial Black'; -fx-font-size: 28px; -fx-text-fill: #F5F5F4; -fx-min-width: 240px; -fx-alignment: center;" text="PASS SLIP" />
                            </children>
                        </VBox>

                        <!-- RIGHT COLUMN CONTAINER COMPRISING INTERNAL SLIP SCHEMATIC METRICS -->
                        <VBox HBox.hgrow="ALWAYS">
                            <children>

                                <!-- ROW SECTION 1: CALENDAR CHRONOLOGY MATRIX HEADER BLOCK -->
                                <HBox style="-fx-border-color: transparent transparent #3D3229 transparent; -fx-border-width: 0 0 2px 0;">
                                    <children>

                                        <!-- YEAR COMPARTMENT ELEMENT -->
                                        <VBox alignment="CENTER" prefWidth="120.0" style="-fx-border-color: transparent #3D3229 transparent transparent; -fx-border-width: 0 2px 0 0; -fx-padding: 8px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-text-fill: #A8A29E;" text="YEAR" />
                                                <TextField fx:id="txtSlipYear" alignment="CENTER" editable="false" prefHeight="28.0" style="-fx-font-family: 'Arial'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: transparent; -fx-padding: 0; -fx-text-fill: #F5F5F4;" text="2026" />
                                            </children>
                                        </VBox>

                                        <!-- LIVE DATE STAMP SELECTION BOX -->
                                        <VBox alignment="CENTER_LEFT" style="-fx-padding: 8px 12px;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #A8A29E;" text="EFFECTIVE SYSTEM LOG DATE" />
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 4px 0 0 0;">
                                                    <children>
                                                        <!-- Dynamic output read directly from calendar backend controller context -->
                                                        <TextField fx:id="txtSlipFormattedDate" editable="false" promptText="Select Current Date Stamp" style="-fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-background-color: transparent; -fx-padding: 0; -fx-font-weight: bold; -fx-text-fill: #D4A853;" text="JUNE 02, 2026" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                    </children>
                                </HBox>

                                <!-- ROW SECTION 2: IDENTITY MATRICES (CLIENT ID & STAFF NAME) -->
                                <HBox style="-fx-border-color: transparent transparent #3D3229 transparent; -fx-border-width: 0 0 2px 0;">
                                    <children>
                                        <!-- Client / Employee ID Field -->
                                        <VBox prefWidth="140.0" style="-fx-border-color: transparent #3D3229 transparent transparent; -fx-border-width: 0 2px 0 0; -fx-padding: 6px 10px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #D6CCC2;" text="CLIENT #:" />
                                                <TextField fx:id="txtSlipClientId" promptText="XXXX" style="-fx-background-color: transparent; -fx-padding: 4px 0 0 0; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #F5F5F4;" />
                                            </children>
                                        </VBox>
                                        <!-- Personnel Full Name Field -->
                                        <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 6px 10px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #D6CCC2;" text="SELECT EMPLOYEE * :" />
                                                <ComboBox fx:id="cmbEmployeeSelect" promptText="Choose from the list" prefWidth="280.0" style="-fx-background-color: transparent; -fx-padding: 4px 0 0 0; -fx-font-family: 'Arial'; -fx-font-size: 13px;" />
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-text-fill: #78716C; -fx-padding: 2px 0 0 0;" text="Employee ID and name will auto-fill below" />
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 6px 0 0 0; -fx-text-fill: #D6CCC2;" text="NAME :" />
                                                <TextField fx:id="txtSlipEmployeeName" editable="false" promptText="Auto-filled on selection" style="-fx-background-color: transparent; -fx-padding: 4px 0 0 0; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #F5F5F4;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- ROW SECTION 3: PURPOSE STATEMENT FIELD BLOCK -->
                                <VBox style="-fx-border-color: transparent transparent #3D3229 transparent; -fx-border-width: 0 0 2px 0; -fx-padding: 8px 10px;">
                                    <children>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #D6CCC2;" text="PURPOSE * :" />
                                        <TextArea fx:id="txtSlipPurpose" prefHeight="55.0" promptText="e.g., Medical appointment, personal errand, official business..." style="-fx-background-color: transparent; -fx-control-inner-background: #1C0A04; -fx-background-insets: 0; -fx-padding: 4px 0 0 0; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-text-fill: #FFFFFF;" wrapText="true" />
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-text-fill: #78716C; -fx-padding: 2px 0 0 0;" text="Minimum 5 characters required" />
                                    </children>
                                </VBox>

                                <!-- ROW SECTION 4: TEMPORAL TELEMETRY MARKS (TIME OUT / TIME IN) -->
                                <VBox style="-fx-border-color: transparent transparent #3D3229 transparent; -fx-border-width: 0 0 2px 0;">
                                    <children>
                                        <HBox>
                                            <children>
                                                <!-- Time Out Input Slot -->
                                                <VBox HBox.hgrow="ALWAYS" style="-fx-border-color: transparent #3D3229 transparent transparent; -fx-border-width: 0 2px 0 0; -fx-padding: 6px 10px;">
                                                    <children>
                                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #D6CCC2;" text="TIME OUT :" />
                                                        <TextField fx:id="txtSlipTimeOut" editable="false" promptText="Auto-recorded" style="-fx-background-color: transparent; -fx-padding: 4px 0 0 0; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-text-fill: #F5F5F4;" />
                                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-text-fill: #78716C; -fx-padding: 2px 0 0 0;" text="Automatically recorded" />
                                                    </children>
                                                </VBox>
                                                <!-- Time In Input Slot -->
                                                <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 6px 10px;">
                                                    <children>
                                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #D6CCC2;" text="ESTIMATED TIME IN * :" />
                                                        <ComboBox fx:id="cmbTimeIn" editable="true" promptText="Select or type time" prefWidth="200.0" style="-fx-background-color: transparent; -fx-padding: 4px 0 0 0; -fx-font-family: 'Arial'; -fx-font-size: 13px;" />
                                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-text-fill: #78716C; -fx-padding: 2px 0 0 0;" text="Format: HH:MM AM/PM (Example: 09:30 AM)" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <!-- DURATION DISPLAY -->
                                        <Label fx:id="lblDuration" style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #D4A853; -fx-padding: 4px 10px 6px 10px;" text="" />
                                    </children>
                                </VBox>

                                <!-- ROW SECTION 5: VALIDATION SIGNATURE BLOCK FOOTER -->
                                <VBox alignment="BOTTOM_CENTER" style="-fx-padding: 6px 0;">
                                    <children>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #D6CCC2; -fx-padding: 0 0 4px 0;" text="ADMIN SIGNATURE :" />
                                        <VBox maxWidth="320.0" alignment="CENTER" style="-fx-border-color: #3D3229; -fx-border-width: 1px; -fx-border-radius: 4px; -fx-background-color: #FFFFFF; -fx-background-radius: 4px; -fx-padding: 4px;">
                                            <children>
                                                <ImageView fx:id="imgAdminSignature" fitHeight="60.0" fitWidth="280.0" preserveRatio="true" />
                                            </children>
                                        </VBox>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-text-fill: #78716C;" text="Auto-signed with your registered signature" />
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- MODAL CONTROL ACTIONS GRID ROW TOOLBAR -->
                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <!-- Terminate Dialog Window Session Button -->
                        <Button fx:id="btnCancelSlipAction" mnemonicParsing="false" prefHeight="36.0" prefWidth="110.0" style="-fx-background-color: #2D2520; -fx-text-fill: #A8A29E; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-color: #3D3229; -fx-border-radius: 6px; -fx-cursor: hand;" text="Dismiss" />

                        <!-- Print Document Frame Event Trigger Button -->
                        <Button fx:id="btnPrintSlipAction" mnemonicParsing="false" prefHeight="36.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-text-fill: #D4A853; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-border-color: #7C0A02; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-cursor: hand;" text="🖨️ Print Slip" />

                        <!-- Commit Record Entry Payload To Active System Database Button -->
                        <Button fx:id="btnSaveSlipAction" mnemonicParsing="false" prefHeight="36.0" prefWidth="160.0" style="-fx-background-color: #7C0A02; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(124,10,2,0.35), 8, 0, 0, 2);" text="💾 Authorize &amp; Log" />
                    </children>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </HBox>

                <Label fx:id="lblSlipStatusMessage" style="-fx-text-fill: #D4A853; -fx-font-family: 'Arial'; -fx-font-size: 12px; -fx-font-weight: bold;" text="" />

            </children>
        </VBox>

    </children>
</VBox>
