<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="userMasterStructure" prefHeight="720.0" prefWidth="1150.0" style="-fx-background-color: #ffffff;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.UserController">

    <!-- TOP BRAND HEADER BAR (Matches Dashboard.fxml exactly) -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="75.0" style="-fx-background-color: #ffffff; -fx-border-color: #800000 transparent #800000 transparent; -fx-border-width: 4px 0 1px 0; -fx-padding: 0 25px 0 15px;" BorderPane.alignment="CENTER">
            <children>
                <!-- PUP Institutional Logo -->
                <ImageView fitHeight="55.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                </ImageView>

                <!-- Branding Text Stack -->
                <VBox alignment="CENTER_LEFT" spacing="2.0">
                    <children>
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Polytechnic University of the Philippines" />
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 17px; -fx-font-style: italic; -fx-text-fill: #333333;" text="Santa Rosa Campus" />
                    </children>
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </VBox>

                <StackPane HBox.hgrow="ALWAYS" />

                <!-- Utility Notification and Menu Controls -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="🔔" />
                        <Button fx:id="btnHamburgerMenuToggle" mnemonicParsing="false" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="☰" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <!-- LEFT NAVIGATION SIDEBAR PANEL (Matches Dashboard.fxml exactly) -->
    <left>
        <VBox fx:id="sidebarNavigationContainer" alignment="TOP_CENTER" prefWidth="240.0" style="-fx-background-color: #800000; -fx-padding: 25px 0 15px 0;" BorderPane.alignment="CENTER">
            <children>
                <!-- Large Main Round Logo Frame -->
                <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                    <VBox.margin>
                        <Insets bottom="40.0" />
                    </VBox.margin>
                </ImageView>

                <!-- Navigation Control Item Switches -->
                <VBox spacing="10.0" style="-fx-padding: 0 12px;" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnSidebarDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Dashboard" />
                        <Button fx:id="btnSidebarMonitoring" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Monitoring and Logs" />
                        <Button fx:id="btnSidebarEmployees" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Employee Management" />
                        <Button fx:id="btnSidebarReports" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Report Generation &amp; History" />
                    </children>
                </VBox>

                <!-- Structural Sidebar Brand Footer Signature -->
                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-opacity: 0.85;" text="2026 PUP - SRC" />
            </children>
        </VBox>
    </left>

    <!-- WORKSPACE MAIN REGION -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #ffffff; -fx-background-color: #ffffff; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="25.0" style="-fx-padding: 30px 40px; -fx-background-color: #ffffff;">
                    <children>

                        <!-- DYNAMIC SUMMARY STATS ROW -->
                        <HBox alignment="CENTER" spacing="25.0">
                            <children>
                                <!-- CARD 1: ACTIVE SYSTEM USERS -->
                                <VBox alignment="CENTER" prefHeight="120.0" prefWidth="320.0" style="-fx-background-color: #800000; -fx-background-radius: 14px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffe600; -fx-background-radius: 14px 14px 0 0; -fx-padding: 6px 15px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #800000; -fx-font-size: 11px;" text="👥 TOTAL SYSTEM USERS" />
                                            </children>
                                        </HBox>
                                        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblTotalUsers" style="-fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 32px; -fx-font-weight: bold;" text="8" />
                                                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-opacity: 0.8;" text="Authorized Portal Admin Staff" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- CARD 2: RECENT SECURITY SESSIONS -->
                                <VBox alignment="CENTER" prefHeight="120.0" prefWidth="320.0" style="-fx-background-color: #ffffff; -fx-background-radius: 14px; -fx-border-color: #e2e8f0; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 8, 0, 0, 3);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #e2e8f0; -fx-background-radius: 13px 13px 0 0; -fx-padding: 6px 15px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 11px;" text="🔐 ACTIVE AUTHORIZATIONS" />
                                            </children>
                                        </HBox>
                                        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblActiveSessions" style="-fx-text-fill: #800000; -fx-font-family: 'Arial'; -fx-font-size: 32px; -fx-font-weight: bold;" text="3 Active" />
                                                <Label style="-fx-text-fill: #718096; -fx-font-size: 12px;" text="System Handlers Logged In" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- USER PROFILE DETAIL MANIPULATION LAYER -->
                        <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                            <children>

                                <!-- FORM CONFIGURATION BAR (LEFT HAND COMPONENT) -->
                                <VBox spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 25px; -fx-background-radius: 12px; -fx-border-color: #edf2f7; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 8, 0, 0, 3);" HBox.hgrow="NEVER" prefWidth="380.0">
                                    <children>

                                        <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 0 0 10px 0; -fx-border-color: transparent transparent #edf2f7 transparent; -fx-border-width: 0 0 1px 0;">
                                            <children>
                                                <VBox style="-fx-background-color: #ffe600; -fx-pref-width: 4px; -fx-pref-height: 16px;" />
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="USER DETAILS &amp; CREDENTIALS" />
                                            </children>
                                        </HBox>

                                        <GridPane vgap="12.0" hgap="10.0">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="100.0" />
                                            </columnConstraints>
                                            <children>
                                                <!-- User ID / Employee Code -->
                                                <VBox spacing="5.0" GridPane.rowIndex="0">
                                                    <children>
                                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" text="User Reference ID / Handle:" />
                                                        <TextField fx:id="txtUserId" promptText="e.g., ADM-2026-01" style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 4px;" />
                                                    </children>
                                                </VBox>

                                                <!-- Full Operator Name -->
                                                <VBox spacing="5.0" GridPane.rowIndex="1">
                                                    <children>
                                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" text="Full Structural Name:" />
                                                        <TextField fx:id="txtUserName" promptText="Enter system handler name..." style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 4px;" />
                                                    </children>
                                                </VBox>

                                                <!-- Security Role Dropdown Selection Map -->
                                                <VBox spacing="5.0" GridPane.rowIndex="2">
                                                    <children>
                                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" text="Assigned Access Control Level:" />
                                                        <ComboBox fx:id="cmbUserRole" maxWidth="Infinity" promptText="Select Authorization Tier" style="-fx-font-size: 13px; -fx-padding: 4px; -fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 4px;" />
                                                    </children>
                                                </VBox>

                                                <!-- Account System Password -->
                                                <VBox spacing="5.0" GridPane.rowIndex="3">
                                                    <children>
                                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 12px;" text="Security Password Gate:" />
                                                        <PasswordField fx:id="txtUserPassword" promptText="••••••••••••" style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 4px;" />
                                                    </children>
                                                </VBox>
                                            </children>
                                            <rowConstraints>
                                                <RowConstraints />
                                                <RowConstraints />
                                                <RowConstraints />
                                                <RowConstraints />
                                            </rowConstraints>
                                        </GridPane>

                                        <!-- Action Form Controller Row Buttons -->
                                        <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10px 0 0 0;">
                                            <children>
                                                <Button fx:id="btnClearUserForm" mnemonicParsing="false" prefHeight="35.0" prefWidth="95.0" style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 4px; -fx-cursor: hand;" text="Reset Form" />
                                                <Button fx:id="btnSaveUserRegistry" mnemonicParsing="false" prefHeight="35.0" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 4px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(128,0,0,0.15), 5, 0, 0, 2);" text="💾 Commit Changes" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="lblUserMessage" style="-fx-text-fill: #800000; -fx-font-size: 12px; -fx-font-weight: bold;" text="" />
                                    </children>
                                </VBox>

                                <!-- LOGGED DIRECTORY TABLE FRAMEWORK (RIGHT HAND COMPONENT) -->
                                <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="📋 ACTIVE RECOGNIZED SYSTEM ACCOUNTS" />
                                            </children>
                                        </HBox>

                                        <TableView fx:id="tblSystemUsersView" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1px;" VBox.vgrow="ALWAYS" prefHeight="350.0">
                                            <columns>
                                                <TableColumn fx:id="colUserRefId" prefWidth="110.0" style="-fx-alignment: CENTER;" text="User ID" />
                                                <TableColumn fx:id="colUserFullName" prefWidth="180.0" style="-fx-alignment: CENTER_LEFT;" text="Personnel Name" />
                                                <TableColumn fx:id="colUserRoleTier" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Role Level" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>

                                        <!-- Selected Row Actions Context Ribbon Toolbar -->
                                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                            <children>
                                                <Button fx:id="btnRevokeAccess" mnemonicParsing="false" prefHeight="34.0" style="-fx-background-color: #fff5f5; -fx-text-fill: #c53030; -fx-border-color: #feb2b2; -fx-border-radius: 4px; -fx-background-radius: 4px; -fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;" text="❌ Revoke Authorization Account" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
