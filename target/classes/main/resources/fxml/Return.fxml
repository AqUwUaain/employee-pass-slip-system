<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="returnMasterStructure" prefHeight="720.0" prefWidth="1150.0" style="-fx-background-color: #ffffff;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReturnController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="75.0" style="-fx-background-color: #ffffff; -fx-border-color: #800000 transparent #800000 transparent; -fx-border-width: 4px 0 1px 0; -fx-padding: 0 25px 0 15px;" BorderPane.alignment="CENTER">
            <children>
                <ImageView fitHeight="55.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                </ImageView>

                <VBox alignment="CENTER_LEFT" spacing="2.0">
                    <children>
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Polytechnic University of the Philippines" />
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 17px; -fx-font-style: italic; -fx-text-fill: #333333;" text="Santa Rosa Campus" />
                    </children>
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </VBox>

                <StackPane HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="🔔" prefHeight="35.0" prefWidth="35.0" />
                        <Button fx:id="btnHamburgerMenuToggle" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="☰" prefHeight="35.0" prefWidth="35.0" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox fx:id="sidebarNavigationContainer" prefWidth="240.0" style="-fx-background-color: #800000; -fx-padding: 25px 0 15px 0;" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                    <VBox.margin>
                        <Insets bottom="40.0" />
                    </VBox.margin>
                </ImageView>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 12px;">
                    <children>
                        <Button fx:id="btnSidebarDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Dashboard" />
                        <Button fx:id="btnSidebarMonitoring" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Monitoring and Logs" />
                        <Button fx:id="btnSidebarEmployees" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Employee Management" />
                        <Button fx:id="btnSidebarReports" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Report Generation &amp; History" />
                    </children>
                </VBox>

                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-opacity: 0.85;" text="2026 PUP - SRC" />
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #ffffff; -fx-background-color: #ffffff; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="25.0" style="-fx-padding: 30px 40px; -fx-background-color: #ffffff;">
                    <children>

                        <HBox alignment="CENTER" spacing="25.0">
                            <children>
                                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="320.0" style="-fx-background-color: #800000; -fx-background-radius: 14px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffe600; -fx-background-radius: 14px 14px 0 0; -fx-padding: 6px 15px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #800000; -fx-font-size: 11px;" text="🏃‍♂️ CURRENTLY OUTSIDE" />
                                            </children>
                                        </HBox>
                                        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblTotalCurrentlyOut" style="-fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 36px; -fx-font-weight: bold;" text="14" />
                                                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-opacity: 0.8;" text="Awaiting Campus Re-entry Logs" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="320.0" style="-fx-background-color: #ffffff; -fx-background-radius: 14px; -fx-border-color: #e2e8f0; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 8, 0, 0, 3);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #e2e8f0; -fx-background-radius: 13px 13px 0 0; -fx-padding: 6px 15px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 11px;" text="✅ TOTAL RETURNED TODAY" />
                                            </children>
                                        </HBox>
                                        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblTotalReturnedToday" style="-fx-text-fill: #800000; -fx-font-family: 'Arial'; -fx-font-size: 36px; -fx-font-weight: bold;" text="32" />
                                                <Label style="-fx-text-fill: #718096; -fx-font-size: 12px;" text="Successfully Settled Slips" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 25px 30px; -fx-background-radius: 12px; -fx-border-color: #edf2f7; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 8, 0, 0, 3);">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 0 0 10px 0; -fx-border-color: transparent transparent #edf2f7 transparent; -fx-border-width: 0 0 1px 0;">
                                    <children>
                                        <VBox style="-fx-background-color: #ffe600; -fx-pref-width: 4px; -fx-pref-height: 16px;" />
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="LOG PERSONNEL RE-ENTRY" />
                                    </children>
                                </HBox>

                                <GridPane hgap="20.0" vgap="18.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="25.0" />
                                        <ColumnConstraints percentWidth="50.0" />
                                        <ColumnConstraints percentWidth="25.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="35.0" />
                                        <RowConstraints minHeight="35.0" />
                                        <RowConstraints minHeight="35.0" />
                                    </rowConstraints>
                                    <children>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 13px;" text="Scan or Enter Client ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="txtReturnSearchId" promptText="Enter PUP-SR-XXXX ID reference..." style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 4px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Button fx:id="btnFetchActiveSlip" mnemonicParsing="false" maxWidth="Infinity" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-background-radius: 4px; -fx-cursor: hand;" text="🔍 Find Slip" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 13px;" text="Identified Personnel Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="txtReturnEmployeeName" editable="false" promptText="Personnel match display name" style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #f7fafc; -fx-border-color: #cbd5e0; -fx-border-radius: 4px; -fx-text-fill: #4a5568;" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="2" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 13px;" text="Verify Return Time In:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="txtReturnTimeInStamp" promptText="e.g., 04:30 PM" style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 4px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Button fx:id="btnConfirmReturnLog" mnemonicParsing="false" maxWidth="Infinity" style="-fx-background-color: #38a169; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8px 15px; -fx-background-radius: 4px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(56,161,105,0.2), 5, 0, 0, 2);" text="📥 Process Re-entry" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                    </children>
                                </GridPane>
                                <Label fx:id="lblReturnStatusMessage" style="-fx-text-fill: #800000; -fx-font-size: 12px; -fx-font-weight: bold;" text="" />
                            </children>
                        </VBox>

                        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="🕒 OUTSTANDING PASS SLIPS REQUIRING RETURN LOGS" />
                                    </children>
                                </HBox>

                                <TableView fx:id="tblOutstandingOutboundView" prefHeight="260.0" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1px;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colReturnSlipId" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Slip ID" />
                                        <TableColumn fx:id="colReturnEmployeeID" prefWidth="140.0" style="-fx-alignment: CENTER;" text="Employee ID" />
                                        <TableColumn fx:id="colReturnFullName" prefWidth="220.0" style="-fx-alignment: CENTER_LEFT;" text="Personnel Name" />
                                        <TableColumn fx:id="colReturnDepartment" prefWidth="140.0" style="-fx-alignment: CENTER;" text="Department" />
                                        <TableColumn fx:id="colReturnTimeOut" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Time Out" />
                                        <TableColumn fx:id="colReturnExpectedIn" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Expected In" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
