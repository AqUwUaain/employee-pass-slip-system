<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="deleteModalRoot" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="450.0" spacing="0.0" style="-fx-background-color: #252220; -fx-background-radius: 12px; -fx-border-color: #7C0A02; -fx-border-radius: 12px; -fx-border-width: 2px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.55), 20, 0, 0, 6);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DeleteEmployeeController">
    <children>

        <!-- MODAL HEADER BAR (Matches Institutional Accent Theme) -->
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #7C0A02; -fx-background-radius: 9px 9px 0 0; -fx-padding: 0 20px;">
            <children>
                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffe600;" text="⚠️ Confirm Deletion" />
            </children>
        </HBox>

        <!-- CONTENT REGION -->
        <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 30px 25px;">
            <children>

                <!-- Warning Alert Icon Element -->
                <Label style="-fx-font-size: 42px;" text="🗑️" />

                <!-- Context Warning Header Text -->
                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #F5F5F4;" text="Delete Employee Profile?" textAlignment="CENTER" />
                        <Label fx:id="lblWarningTargetName" style="-fx-font-family: 'Arial'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #D4A853;" text="[Employee Name Placeholder]" textAlignment="CENTER" />
                    </children>
                </VBox>

                <!-- Informational Warning Paragraph -->
                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-text-fill: #A8A29E; -fx-line-spacing: 3px;" text="Warning: This administrative action is permanent. Purging this profile will immediately revoke system access and disconnect all corresponding data logs." textAlignment="CENTER" wrapText="true" />

                <!-- ACTION BUTTON CONTROLS ROW -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>

                        <!-- Cancel / Close Modal Option Button -->
                        <Button fx:id="btnCancelDelete" mnemonicParsing="false" prefHeight="38.0" prefWidth="130.0" style="-fx-background-color: #2D2520; -fx-text-fill: #A8A29E; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-color: #3D3229; -fx-border-radius: 6px; -fx-cursor: hand;" text="No, Cancel" />

                        <!-- Confirm / Purge Target Option Button -->
                        <Button fx:id="btnConfirmDelete" mnemonicParsing="false" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #7C0A02; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(124,10,2,0.35), 8, 0, 0, 2);" text="Yes, Delete Profile" />

                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>

            </children>
        </VBox>

    </children>
</VBox>