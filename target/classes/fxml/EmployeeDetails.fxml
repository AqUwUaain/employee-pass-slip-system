<?xml version="1.0" encoding="UTF-8"?>

<!--
    System Module: Employee Information Management Card View
    View Reference: EmployeeDetails.fxml
    Target Design Guide Compatibility: Dashboard.fxml Identity System
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="employeeDetailsStructure" prefHeight="720.0" prefWidth="1150.0" style="-fx-background-color: #ffffff;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EmployeeDetailsController">

    <!-- TOP BRAND HEADER BAR (Matches Dashboard.fxml exactly) -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="75.0" style="-fx-background-color: #ffffff; -fx-border-color: #800000 transparent #800000 transparent; -fx-border-width: 4px 0 1px 0; -fx-padding: 0 25px 0 15px;" BorderPane.alignment="CENTER">
            <children>
                <!-- PUP Institutional Logo -->
                <ImageView fitHeight="55.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                </ImageView>

                <!-- Branding Text Stack -->
                <VBox alignment="CENTER_LEFT" spacing="2.0">
                    <children>
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Polytechnic University of the Philippines" />
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 17px; -fx-font-style: italic; -fx-text-fill: #333333;" text="Santa Rosa Campus" />
                    </children>
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </VBox>

                <StackPane HBox.hgrow="ALWAYS" />

                <!-- Utility Notification and Menu Controls -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="🔔" prefHeight="35.0" prefWidth="35.0" />
                        <Button fx:id="btnHamburgerMenuToggle" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="☰" prefHeight="35.0" prefWidth="35.0" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <!-- LEFT REGISTRY NAVIGATION SIDEBAR PANEL (Matches Dashboard.fxml exactly) -->
    <left>
        <VBox fx:id="sidebarNavigationContainer" prefWidth="240.0" style="-fx-background-color: #800000; -fx-padding: 25px 0 15px 0;" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <!-- Large Main Round Logo Frame -->
                <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                    <VBox.margin>
                        <Insets bottom="40.0" />
                    </VBox.margin>
                </ImageView>

                <!-- Navigation Control Item Switches -->
                <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 12px;">
                    <children>
                        <Button fx:id="btnSidebarDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Dashboard" />
                        <Button fx:id="btnSidebarMonitoring" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Monitoring and Logs" />
                        <Button fx:id="btnSidebarEmployees" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Employee Management" />
                        <Button fx:id="btnSidebarReports" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Report Generation &amp; History" />
                    </children>
                </VBox>

                <!-- Structural Sidebar Brand Footer Signature -->
                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-opacity: 0.85;" text="2026 PUP - SRC" />
            </children>
        </VBox>
    </left>

    <!-- WORKSPACE REGION EMBEDDING THE EXTENDED PROFILE DATA SHEET -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #ffffff; -fx-background-color: #ffffff; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="25.0" style="-fx-padding: 30px 40px; -fx-background-color: #ffffff;">
                    <children>

                        <!-- TOOLBAR NAVIGATION / CONTEXT BACK BUTTON ACTION -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button fx:id="btnBackToDirectory" mnemonicParsing="false" style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8px 16px; -fx-background-radius: 6px; -fx-cursor: hand;" text="⬅ Back to Employee Directory" />
                                <StackPane HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnEditEmployeeProfile" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8px 20px; -fx-background-radius: 6px; -fx-cursor: hand;" text="✏️ Edit Profile Info" />
                            </children>
                        </HBox>

                        <!-- MASTER BIO SUMMARY BANNER CARD -->
                        <HBox alignment="CENTER_LEFT" spacing="25.0" style="-fx-background-color: #ffffff; -fx-padding: 25px 30px; -fx-background-radius: 12px; -fx-border-color: #edf2f7; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 8, 0, 0, 3);">
                            <children>
                                <!-- Rounded Profile Avatar Mockup -->
                                <VBox alignment="CENTER" style="-fx-background-color: #f7fafc; -fx-border-color: #cbd5e0; -fx-border-width: 1px; -fx-border-radius: 50px; -fx-background-radius: 50px; -fx-padding: 15px;" prefHeight="90.0" prefWidth="90.0">
                                    <children>
                                        <Label style="-fx-font-size: 40px;" text="👤" />
                                    </children>
                                </VBox>

                                <!-- Core Tracking Details Column -->
                                <VBox alignment="CENTER_LEFT" spacing="6.0">
                                    <children>
                                        <Label fx:id="lblHeaderEmployeeName" style="-fx-font-family: 'Arial'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Maxwell Sterling" />
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <children>
                                                <Label fx:id="lblHeaderDepartmentTag" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 4px 10px; -fx-background-radius: 12px;" text="EDUCATION" />
                                                <Label fx:id="lblHeaderPositionTitle" style="-fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-text-fill: #4a5568; -fx-font-weight: bold;" text="Academic Professor" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- DETAILED SPECIFICATION GRID FORM SHEET -->
                        <VBox spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 25px 30px; -fx-background-radius: 12px; -fx-border-color: #edf2f7; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 8, 0, 0, 3);">
                            <children>

                                <!-- Section Label Divider Row -->
                                <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 0 0 10px 0; -fx-border-color: transparent transparent #edf2f7 transparent; -fx-border-width: 0 0 1px 0;">
                                    <children>
                                        <VBox style="-fx-background-color: #ffe600; -fx-pref-width: 4px; -fx-pref-height: 16px;" />
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="PERSONNEL DATA PROFILE SPECIFICATIONS" />
                                    </children>
                                </HBox>

                                <!-- Layout Grid Content Fields -->
                                <GridPane hgap="20.0" vgap="18.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="25.0" />
                                        <ColumnConstraints percentWidth="75.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                    </rowConstraints>
                                    <children>

                                        <!-- Row 1: Employee Registration ID -->
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #718096; -fx-font-size: 13px;" text="Employee ID Number:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label fx:id="lblValEmployeeId" style="-fx-font-family: 'Arial'; -fx-text-fill: #2d3748; -fx-font-size: 14px; -fx-font-weight: bold;" text="PUP-SR-2026-0042" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <!-- Row 2: Contact Information Email -->
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #718096; -fx-font-size: 13px;" text="Email Address Reference:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <Label fx:id="lblValEmail" style="-fx-font-family: 'Arial'; -fx-text-fill: #2d3748; -fx-font-size: 14px;" text="m.sterling@santarosa.pup.edu.ph" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <!-- Row 3: Contact Mobile Phone -->
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #718096; -fx-font-size: 13px;" text="Contact Mobile Phone:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <Label fx:id="lblValMobile" style="-fx-font-family: 'Arial'; -fx-text-fill: #2d3748; -fx-font-size: 14px;" text="+63 (917) 555-0192" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <!-- Row 4: Corporate Assigned Shift -->
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #718096; -fx-font-size: 13px;" text="Assigned Shift Schedule:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <Label fx:id="lblValShiftSchedule" style="-fx-font-family: 'Arial'; -fx-text-fill: #2d3748; -fx-font-size: 14px;" text="Regular Mon-Fri (08:00 AM - 05:00 PM)" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                        <!-- Row 5: Account Authorization Lifecycle Status -->
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #718096; -fx-font-size: 13px;" text="System Registry Status:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <Label fx:id="lblValRegistryStatus" style="-fx-font-family: 'Arial'; -fx-text-fill: #38a169; -fx-font-size: 14px; -fx-font-weight: bold;" text="Active Personnel Clear" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>