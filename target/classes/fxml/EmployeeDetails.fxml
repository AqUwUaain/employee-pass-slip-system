<?xml version="1.0" encoding="UTF-8"?>

<!--
    System Module: Employee Information Management Card View
    View Reference: EmployeeDetails.fxml
    Target Design Guide Compatibility: Dashboard.fxml Identity System
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="employeeDetailsStructure" prefHeight="720.0" prefWidth="1150.0" styleClass="page-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EmployeeDetailsController">

    <!-- TOP HEADER BAR (Matches Dashboard.fxml exactly) -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="62.0" styleClass="header-clean" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label text="Employee Details" styleClass="pg-title" />
                        <Label text="View personnel profile" styleClass="pg-sub" />
                    </children>
                </VBox>
                <StackPane HBox.hgrow="ALWAYS" />
                <HBox spacing="12.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnThemeToggle" mnemonicParsing="false" text="☀" prefHeight="38.0" prefWidth="38.0" styleClass="icon-circle" />
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" text="&#x1F514;" prefHeight="38.0" prefWidth="38.0" styleClass="icon-circle" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR (Matches Dashboard.fxml exactly) -->
    <left>
        <VBox fx:id="sidebarNavigationContainer" prefWidth="240.0" styleClass="sidebar-dark" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 0 0 36px 0;">
                    <children>
                        <ImageView fitHeight="56.0" fitWidth="56.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../images/pup_logo.png" /></image>
                        </ImageView>
                        <Label text="PUP SRC" styleClass="sidebar-badge" />
                    </children>
                </VBox>
                <VBox spacing="4.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 14px;">
                    <children>
                        <Label text="MAIN MENU" styleClass="sidebar-section-label" />
                        <Button fx:id="btnSidebarDashboard" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Dashboard" styleClass="nav-item" />
                        <Button fx:id="btnSidebarMonitoring" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   System Logs" styleClass="nav-item" />
                        <Button fx:id="btnSidebarLogReturn" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Log Return &amp; Monitoring" styleClass="nav-item" />
                        <Button fx:id="btnManageEmployees" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Manage Employees  ▾" styleClass="nav-item" />
                        <VBox fx:id="manageEmployeesSubMenu" styleClass="nav-sub-menu" managed="false" visible="false">
                            <children>
                                <Button fx:id="btnSidebarEmployeeDirectory" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Employee Directory" styleClass="nav-sub-item nav-sub-active" />
                                <Button fx:id="btnSidebarAddEmployee" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Add New Employee" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarImportEmployee" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Import Employees" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarReports" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Reports" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarUsers" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Users" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarSignatures" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Signatures" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarRequests" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Settings" styleClass="nav-sub-item" />
                            </children>
                        </VBox>
                        <Label text="ACCOUNT" styleClass="sidebar-section-label" />
                        <Button fx:id="btnLogout" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Logout" styleClass="nav-item" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" style="-fx-padding: 16px;">
                    <Label text="2026 PUP — SRC" styleClass="sidebar-footer-label" />
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll-pane" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="25.0" style="-fx-padding: 30px 40px;">
                    <children>

                        <!-- TOOLBAR NAVIGATION / CONTEXT BACK BUTTON ACTION -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button fx:id="btnBackToDirectory" mnemonicParsing="false" styleClass="btn-neutral" text="&#x2190; Back to Employee Directory" />
                                <StackPane HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnEditEmployeeProfile" mnemonicParsing="false" styleClass="btn-gold" text="&#x270F; Edit Profile Info" />
                            </children>
                        </HBox>

                        <!-- MASTER BIO SUMMARY BANNER CARD -->
                        <HBox alignment="CENTER_LEFT" spacing="25.0" styleClass="card" style="-fx-padding: 25px 30px;">
                            <children>
                                <VBox alignment="CENTER" styleClass="icon-circle" style="-fx-padding: 15px; -fx-font-size: 28px;" prefHeight="90.0" prefWidth="90.0">
                                    <children>
                                        <Label style="-fx-font-size: 40px;" text="&#x1F464;" />
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER_LEFT" spacing="6.0">
                                    <children>
                                        <Label fx:id="lblHeaderEmployeeName" styleClass="sec-title" text="Maxwell Sterling" />
                                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                                            <children>
                                                <Label fx:id="lblHeaderDepartmentTag" style="-fx-background-color: #7C0A02; -fx-text-fill: #ffffff; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 4px 10px; -fx-background-radius: 12px;" text="EDUCATION" />
                                                <Label fx:id="lblHeaderPositionTitle" style="-fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-text-fill: #A8A29E; -fx-font-weight: bold;" text="Academic Professor" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- DETAILED SPECIFICATION GRID FORM SHEET -->
                        <VBox spacing="15.0" styleClass="card" style="-fx-padding: 25px 30px;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 0 0 10px 0; -fx-border-color: transparent transparent #3D3229 transparent; -fx-border-width: 0 0 1px 0;">
                                    <children>
                                        <VBox style="-fx-background-color: #D4A853; -fx-pref-width: 4px; -fx-pref-height: 16px;" />
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #D4A853;" text="PERSONNEL DATA PROFILE SPECIFICATIONS" />
                                    </children>
                                </HBox>
                                <GridPane hgap="20.0" vgap="18.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="25.0" />
                                        <ColumnConstraints percentWidth="75.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                        <RowConstraints minHeight="30.0" />
                                    </rowConstraints>
                                    <children>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Employee ID Number:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label fx:id="lblValEmployeeId" styleClass="form-label" style="-fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-font-weight: bold;" text="" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Email Address Reference:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <Label fx:id="lblValEmail" styleClass="form-label" style="-fx-font-family: 'Arial'; -fx-font-size: 14px;" text="" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Contact Mobile Phone:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <Label fx:id="lblValMobile" styleClass="form-label" style="-fx-font-family: 'Arial'; -fx-font-size: 14px;" text="" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Assigned Shift Schedule:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <Label fx:id="lblValShiftSchedule" styleClass="form-label" style="-fx-font-family: 'Arial'; -fx-font-size: 14px;" text="" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="System Registry Status:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <Label fx:id="lblValRegistryStatus" style="-fx-font-family: 'Arial'; -fx-text-fill: #38a169; -fx-font-size: 14px; -fx-font-weight: bold;" text="Active Personnel Record" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Assigned Manager:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                        <Label fx:id="lblValManager" styleClass="form-label" style="-fx-font-family: 'Arial'; -fx-font-size: 14px;" text="" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Home Address:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                        <Label fx:id="lblValAddress" styleClass="form-label" style="-fx-font-family: 'Arial'; -fx-font-size: 14px;" text="" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Emergency Contact:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                        <Label fx:id="lblValEmergencyContact" styleClass="form-label" style="-fx-font-family: 'Arial'; -fx-font-size: 14px;" text="" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
