<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="passSlipMasterStructure" prefHeight="720.0" prefWidth="1150.0" styleClass="page-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.UserListController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="75.0" styleClass="table-header-bar" BorderPane.alignment="CENTER">
            <children>
                <ImageView fitHeight="55.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="2.0">
                    <children>
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #F5F5F4;" text="Polytechnic University of the Philippines" />
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 17px; -fx-font-style: italic; -fx-text-fill: #D6CCC2;" text="Santa Rosa Campus" />
                    </children>
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </VBox>
                <StackPane HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #7C0A02; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="ðŸ””" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox fx:id="sidebarNavigationContainer" alignment="TOP_CENTER" prefWidth="240.0" style="-fx-background-color: linear-gradient(to bottom, #1C0A04, #2D1208, #3D0C02); -fx-padding: 25px 0 15px 0;" BorderPane.alignment="CENTER">
            <children>
                <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                    <VBox.margin>
                        <Insets bottom="40.0" />
                    </VBox.margin>
                </ImageView>
                <VBox spacing="10.0" style="-fx-padding: 0 12px;" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnSidebarDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Dashboard" />
                        <Button fx:id="btnSidebarMonitoring" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="System Logs" />
                        <Button fx:id="btnSidebarEmployees" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Employee Management" />
                        <Button fx:id="btnSidebarReports" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Report Generation &amp; History" />
                    </children>
                </VBox>
                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-opacity: 0.85;" text="2026 PUP - SRC" />
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #1E1B18; -fx-background-color: #1E1B18; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="25.0" style="-fx-padding: 30px 40px; -fx-background-color: #1E1B18;">
                    <children>

                        <VBox spacing="20.0" style="-fx-background-color: #252220; -fx-padding: 30px; -fx-background-radius: 12px; -fx-border-color: #3D3229; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 8, 0, 0, 3);">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 0 0 10px 0; -fx-border-color: transparent transparent #3D3229 transparent; -fx-border-width: 0 0 1px 0;">
                                    <children>
                                        <VBox style="-fx-background-color: #D4A853; -fx-pref-width: 4px; -fx-pref-height: 16px;" />
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #D4A853;" text="CREATE NEW OFFICIAL OUTBOUND PASS SLIP" />
                                    </children>
                                </HBox>

                                <GridPane hgap="20.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" />
                                        <ColumnConstraints percentWidth="15.0" />
                                        <ColumnConstraints percentWidth="35.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="40.0" />
                                        <RowConstraints minHeight="40.0" />
                                        <RowConstraints minHeight="80.0" />
                                        <RowConstraints minHeight="40.0" />
                                    </rowConstraints>
                                    <children>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Client # (Employee ID):" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="txtSlipClientId" promptText="e.g., PUP-SR-2026" style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #2D2520; -fx-border-color: #3D3229; -fx-border-radius: 4px; -fx-text-fill: #F5F5F4;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Full Name:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <TextField fx:id="txtSlipEmployeeName" promptText="Enter outbound employee name..." style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #2D2520; -fx-border-color: #3D3229; -fx-border-radius: 4px; -fx-text-fill: #F5F5F4;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Date Designation:"  GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="txtSlipCurrentDate" promptText="YYYY-MM-DD" style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #2D2520; -fx-border-color: #3D3229; -fx-border-radius: 4px; -fx-text-fill: #F5F5F4;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Department:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="cmbSlipDepartment" maxWidth="Infinity" promptText="Select Unit" style="-fx-font-size: 13px; -fx-padding: 4px; -fx-background-color: #2D2520; -fx-border-color: #3D3229; -fx-border-radius: 4px;" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Purpose of Travel:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextArea fx:id="txtSlipPurpose" promptText="State official destination or leave context details clearly here..." wrapText="true" style="-fx-font-size: 13px; -fx-background-color: #2D2520; -fx-border-color: #3D3229; -fx-border-radius: 4px; -fx-text-fill: #F5F5F4;" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="2" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Time Out (Departure):" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <TextField fx:id="txtSlipTimeOut" promptText="00:00 AM/PM" style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #2D2520; -fx-border-color: #3D3229; -fx-border-radius: 4px; -fx-text-fill: #F5F5F4;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #A8A29E; -fx-font-size: 13px;" text="Time In:" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                        <TextField fx:id="txtSlipExpectedIn" promptText="00:00 AM/PM" style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #2D2520; -fx-border-color: #3D3229; -fx-border-radius: 4px; -fx-text-fill: #F5F5F4;" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                                    </children>
                                </GridPane>

                                <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 15px 0 0 0; -fx-border-color: #3D3229 transparent transparent transparent; -fx-border-width: 1px 0 0 0;">
                                    <children>
                                        <Button fx:id="btnResetSlipForm" mnemonicParsing="false" prefHeight="38.0" prefWidth="110.0" style="-fx-background-color: #2D2520; -fx-text-fill: #A8A29E; -fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 4px; -fx-border-color: #3D3229; -fx-border-radius: 4px; -fx-cursor: hand;" text="Clear Fields" />
                                        <Button fx:id="btnIssuePassSlip" mnemonicParsing="false" prefHeight="38.0" prefWidth="180.0" style="-fx-background-color: #7C0A02; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 4px; -fx-cursor: hand;" text="ðŸŽŸï¸ Issue Outbound Pass" />
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>

