<?xml version="1.0" encoding="UTF-8"?>

<!--
    System Module: Campus Monitoring & Security Lifecycle
    View Reference: PassSlip.fxml Pop-up Modal Document View
    Target Design Guide Compatibility: Dashboard.fxml Identity System
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="passSlipModalRoot" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="650.0" spacing="0.0" styleClass="pass-slip-border" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PassSlipController">
    <children>

        <!-- MODAL HEADER BAR (Matches Institutional Dashboard Identity) -->
        <HBox alignment="CENTER_LEFT" prefHeight="55.0" styleClass="modal-top">
            <children>
                <Label text="🎫 SYSTEM PASS SLIP REGISTRY" style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffe600;" />
                <StackPane HBox.hgrow="ALWAYS" />
                <Button fx:id="btnTopClose" mnemonicParsing="false" styleClass="btn-top-close" text="✕" />
            </children>
        </HBox>

        <!-- CORE CONTAINER WRAPPER -->
        <VBox spacing="12.0" style="-fx-padding: 20px 25px;">
            <children>

                <!-- INSTRUCTION BANNER -->
                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="pass-slip-section" style="-fx-padding: 10px 14px; -fx-background-color: rgba(212,168,83,0.1);">
                    <children>
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #D4A853;" text="&#x2139;" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #D4A853; -fx-wrap-text: true;" text="Select an employee, enter the purpose, and choose an estimated return time. Fields marked with * are required." HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <!-- THE STRUCTURAL SLIP DOCUMENT CONTAINER LAYER -->
                <HBox styleClass="pass-slip-border">
                    <children>

                        <!-- VERTICAL LEFT BAR SIDE TITLE: PASS SLIP -->
                        <VBox alignment="CENTER" prefWidth="65.0" styleClass="pass-slip-left-panel" style="-fx-padding: 10px 0;">
                            <children>
                                <Label rotate="-90.0" styleClass="pass-slip-title" text="PASS SLIP" />
                            </children>
                        </VBox>

                        <!-- RIGHT COLUMN CONTAINER COMPRISING INTERNAL SLIP SCHEMATIC METRICS -->
                        <VBox HBox.hgrow="ALWAYS" styleClass="pass-slip-left-border">
                            <children>

                                <!-- ROW SECTION 1: CALENDAR CHRONOLOGY MATRIX HEADER BLOCK -->
                                <HBox styleClass="pass-slip-border-bottom">
                                    <children>

                                        <!-- YEAR COMPARTMENT ELEMENT -->
                                        <VBox alignment="CENTER" prefWidth="120.0" styleClass="pass-slip-border-right" style="-fx-padding: 8px;">
                                            <children>
                                                <Label styleClass="pass-slip-year-label" text="YEAR" />
                                                <TextField fx:id="txtSlipYear" alignment="CENTER" editable="false" prefHeight="28.0" styleClass="pass-slip-year-value" text="2026" />
                                            </children>
                                        </VBox>

                                        <!-- LIVE DATE STAMP SELECTION BOX -->
                                        <VBox alignment="CENTER_LEFT" style="-fx-padding: 8px 12px;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="pass-slip-date-label" text="EFFECTIVE SYSTEM LOG DATE" />
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 4px 0 0 0;">
                                                    <children>
                                                        <TextField fx:id="txtSlipFormattedDate" editable="false" promptText="Select Current Date Stamp" styleClass="pass-slip-date-value" text="JUNE 02, 2026" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                    </children>
                                </HBox>

                                <!-- ROW SECTION 2: IDENTITY MATRICES (CLIENT ID & STAFF NAME) -->
                                <HBox styleClass="pass-slip-border-bottom">
                                    <children>
                                        <!-- Client / Employee ID Field -->
                                        <VBox prefWidth="140.0" styleClass="pass-slip-border-right" style="-fx-padding: 6px 10px;">
                                            <children>
                                                <Label styleClass="pass-slip-label" text="CLIENT #:" />
                                                <TextField fx:id="txtSlipClientId" promptText="XXXX" styleClass="pass-slip-input" />
                                            </children>
                                        </VBox>
                                        <!-- Personnel Full Name Field -->
                                        <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 6px 10px;">
                                            <children>
                                                <Label styleClass="pass-slip-label" text="SELECT EMPLOYEE * :" />
                                                <ComboBox fx:id="cmbEmployeeSelect" promptText="Choose from the list" prefWidth="280.0" styleClass="combo-box" />
                                                <Label styleClass="pass-slip-hint" text="Employee ID and name will auto-fill below" />
                                                <Label styleClass="pass-slip-label" style="-fx-padding: 6px 0 0 0;" text="NAME :" />
                                                <TextField fx:id="txtSlipEmployeeName" editable="false" promptText="Auto-filled on selection" styleClass="pass-slip-input" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- ROW SECTION 3: PURPOSE STATEMENT FIELD BLOCK -->
                                <VBox styleClass="pass-slip-section" style="-fx-padding: 8px 10px;">
                                    <children>
                                        <Label styleClass="pass-slip-label" text="PURPOSE * :" />
                                        <TextArea fx:id="txtSlipPurpose" prefHeight="55.0" promptText="e.g., Medical appointment, personal errand, official business..." styleClass="pass-slip-purpose" wrapText="true" />
                                        <Label styleClass="pass-slip-hint" text="Minimum 5 characters required" />
                                    </children>
                                </VBox>

                                <!-- ROW SECTION 4: TEMPORAL TELEMETRY MARKS (TIME OUT / ACTUAL TIME OUT / TIME IN) -->
                                <VBox styleClass="pass-slip-section">
                                    <children>
                                        <HBox>
                                            <children>
                                                <!-- Time Out Input Slot (auto-recorded, read-only) -->
                                                <VBox prefWidth="160.0" styleClass="pass-slip-border-right" style="-fx-padding: 6px 10px;">
                                                    <children>
                                                        <Label styleClass="pass-slip-label" text="TIME OUT :" />
                                                        <TextField fx:id="txtSlipTimeOut" editable="false" promptText="Auto-recorded" styleClass="pass-slip-input" />
                                                        <Label styleClass="pass-slip-hint" text="Automatically recorded" />
                                                    </children>
                                                </VBox>
                                                <!-- Actual Time Out Input Slot (editable for admin) -->
                                                <VBox fx:id="vboxActualTimeOut" prefWidth="180.0" styleClass="pass-slip-border-right" style="-fx-padding: 6px 10px;">
                                                    <children>
                                                        <Label styleClass="pass-slip-label" text="ACTUAL TIME OUT :" />
                                                        <ComboBox fx:id="cmbActualTimeOut" editable="true" promptText="Select or type time" prefWidth="160.0" styleClass="combo-box" />
                                                        <Label styleClass="pass-slip-hint" text="When employee actually departed" />
                                                    </children>
                                                </VBox>
                                                <!-- Time In Input Slot -->
                                                <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 6px 10px;">
                                                    <children>
                                                        <Label styleClass="pass-slip-label" text="ESTIMATED TIME IN * :" />
                                                        <ComboBox fx:id="cmbTimeIn" editable="true" promptText="Select or type time" prefWidth="200.0" styleClass="combo-box" />
                                                        <Label styleClass="pass-slip-hint" text="Format: HH:MM AM/PM (Example: 09:30 AM)" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <!-- DURATION DISPLAY -->
                                        <Label fx:id="lblDuration" styleClass="pass-slip-duration" text="" />
                                    </children>
                                </VBox>

                                <!-- ROW SECTION 5a: REQUESTER SIGNATURE (staff only) -->
                                <VBox fx:id="vboxRequesterSignature" alignment="BOTTOM_CENTER" style="-fx-padding: 6px 0;">
                                    <children>
                                        <Label styleClass="pass-slip-label" style="-fx-padding: 0 0 4px 0;" text="YOUR SIGNATURE :" />
                                        <VBox maxWidth="320.0" alignment="CENTER" styleClass="pass-slip-signature-box">
                                            <children>
                                                <ImageView fx:id="imgRequesterSignature" fitHeight="60.0" fitWidth="280.0" preserveRatio="true" />
                                            </children>
                                        </VBox>
                                        <Label fx:id="lblRequesterSignatureHint" styleClass="pass-slip-footer-label" text="" />
                                    </children>
                                </VBox>

                                <!-- ROW SECTION 5b: ADMIN SIGNATURE -->
                                <VBox alignment="BOTTOM_CENTER" style="-fx-padding: 6px 0;">
                                    <children>
                                        <Label styleClass="pass-slip-label" style="-fx-padding: 0 0 4px 0;" text="ADMIN SIGNATURE :" />
                                        <VBox maxWidth="320.0" alignment="CENTER" styleClass="pass-slip-signature-box">
                                            <children>
                                                <ImageView fx:id="imgAdminSignature" fitHeight="60.0" fitWidth="280.0" preserveRatio="true" />
                                            </children>
                                        </VBox>
                                        <Label styleClass="pass-slip-footer-label" text="Auto-signed with your registered signature" />
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- MODAL CONTROL ACTIONS GRID ROW TOOLBAR -->
                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button fx:id="btnCancelSlipAction" mnemonicParsing="false" prefHeight="36.0" prefWidth="110.0" styleClass="btn-dismiss" text="Dismiss" />
                        <Button fx:id="btnSaveSlipAction" mnemonicParsing="false" prefHeight="36.0" prefWidth="180.0" styleClass="btn-authorize" text="&#x1F4BE; Save" />
                    </children>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </HBox>

                <Label fx:id="lblSlipStatusMessage" styleClass="pass-slip-status" text="" />

            </children>
        </VBox>

    </children>
</VBox>
