<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="420.0" style="-fx-background-color: #252220; -fx-background-radius: 20px; -fx-padding: 40px;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ResetPasswordController">
    <children>
        <Label text="Reset Password Required" style="-fx-text-fill: #D4A853; -fx-font-size: 22px; -fx-font-weight: bold;" VBox.vgrow="NEVER" />
        <Label text="Your password has been approved for reset. Please enter a new password." style="-fx-text-fill: #A8A29E; -fx-font-size: 14px; -fx-wrap-text: true;" VBox.vgrow="NEVER" />
        <VBox spacing="8.0" VBox.vgrow="NEVER">
            <children>
                <Label text="NEW PASSWORD" style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 11px; -fx-font-weight: bold;" />
                <PasswordField fx:id="newPasswordField" promptText="Enter new password" style="-fx-background-color: rgba(255,255,255,0.06); -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1.5px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 14px 16px; -fx-font-size: 14px; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.25); -fx-pref-width: 340px;" />
            </children>
        </VBox>
        <VBox spacing="8.0" VBox.vgrow="NEVER">
            <children>
                <Label text="CONFIRM NEW PASSWORD" style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 11px; -fx-font-weight: bold;" />
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" style="-fx-background-color: rgba(255,255,255,0.06); -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1.5px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 14px 16px; -fx-font-size: 14px; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.25); -fx-pref-width: 340px;" />
            </children>
        </VBox>
        <Label fx:id="resetMessageLabel" text="" style="-fx-font-size: 12px;" VBox.vgrow="NEVER" />
        <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="NEVER">
            <children>
                <Button fx:id="submitBtn" text="Reset Password" style="-fx-background-color: linear-gradient(to right, #C9951A, #D4A853); -fx-text-fill: #1C1917; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12px; -fx-padding: 11px 28px; -fx-effect: dropshadow(three-pass-box, rgba(201,149,26,0.25), 8, 0, 0, 2); -fx-cursor: hand;" />
            </children>
        </HBox>
    </children>
</VBox>
