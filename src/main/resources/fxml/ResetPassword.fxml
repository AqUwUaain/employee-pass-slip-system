<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="420.0" styleClass="modal-box" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ResetPasswordController">
    <children>
        <VBox alignment="CENTER_LEFT" spacing="4.0" styleClass="modal-top" style="-fx-padding: 20px 28px;">
            <children>
                <Label text="Reset Password Required" styleClass="dialog-title" VBox.vgrow="NEVER" />
                <Label text="Your password has been approved for reset. Please enter a new password." styleClass="dialog-subtitle" VBox.vgrow="NEVER" />
            </children>
        </VBox>
        <VBox spacing="16.0" style="-fx-padding: 24px 28px;">
            <children>
                <VBox spacing="8.0" VBox.vgrow="NEVER">
                    <children>
                        <Label text="NEW PASSWORD" styleClass="form-label" />
                        <PasswordField fx:id="newPasswordField" promptText="Enter new password" styleClass="text-field" prefWidth="340.0" />
                    </children>
                </VBox>
                <VBox spacing="8.0" VBox.vgrow="NEVER">
                    <children>
                        <Label text="CONFIRM NEW PASSWORD" styleClass="form-label" />
                        <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="text-field" prefWidth="340.0" />
                    </children>
                </VBox>
                <Label fx:id="resetMessageLabel" text="" style="-fx-font-size: 12px;" VBox.vgrow="NEVER" />
                <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="NEVER">
                    <children>
                        <Button fx:id="submitBtn" text="Reset Password" styleClass="btn-gold" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
