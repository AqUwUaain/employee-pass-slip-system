<?xml version="1.0" encoding="UTF-8"?>

<!--
    System Module: Employee Directory Management Master Entry
    View Reference: EmployeeController.fxml
    Target Design Guide Compatibility: Dashboard.fxml Identity System
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="employeeMasterStructure" prefHeight="720.0" prefWidth="1150.0" style="-fx-background-color: #ffffff;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EmployeeController">

    <!-- TOP BRAND HEADER BAR (Matches Dashboard.fxml exactly) -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="75.0" style="-fx-background-color: #ffffff; -fx-border-color: #800000 transparent #800000 transparent; -fx-border-width: 4px 0 1px 0; -fx-padding: 0 25px 0 15px;" BorderPane.alignment="CENTER">
            <children>
                <!-- PUP Institutional Logo -->
                <ImageView fitHeight="55.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                </ImageView>

                <!-- Branding Text Stack -->
                <VBox alignment="CENTER_LEFT" spacing="2.0">
                    <children>
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Polytechnic University of the Philippines" />
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 17px; -fx-font-style: italic; -fx-text-fill: #333333;" text="Santa Rosa Campus" />
                    </children>
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </VBox>

                <StackPane HBox.hgrow="ALWAYS" />

                <!-- Utility Notification and Menu Controls -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="🔔" prefHeight="35.0" prefWidth="35.0" />
                        <Button fx:id="btnHamburgerMenuToggle" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="☰" prefHeight="35.0" prefWidth="35.0" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <!-- LEFT REGISTRY NAVIGATION SIDEBAR PANEL (Matches Dashboard.fxml exactly) -->
    <left>
        <VBox fx:id="sidebarNavigationContainer" prefWidth="240.0" style="-fx-background-color: #800000; -fx-padding: 25px 0 15px 0;" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <!-- Large Main Round Logo Frame -->
                <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                    <VBox.margin>
                        <Insets bottom="40.0" />
                    </VBox.margin>
                </ImageView>

                <!-- Navigation Control Item Switches -->
                <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 12px;">
                    <children>
                        <Button fx:id="btnSidebarDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Dashboard" />
                        <Button fx:id="btnSidebarMonitoring" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Monitoring and Logs" />
                        <Button fx:id="btnSidebarEmployees" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Employee Management" />
                        <Button fx:id="btnSidebarReports" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Report Generation &amp; History" />
                    </children>
                </VBox>

                <!-- Structural Sidebar Brand Footer Signature -->
                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-opacity: 0.85;" text="2026 PUP - SRC" />
            </children>
        </VBox>
    </left>

    <!-- MAIN DYNAMIC CONTENT WORKSPACE AREA -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #ffffff; -fx-background-color: #ffffff; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <!-- This dynamic inner container changes views/modules on action trigger -->
                <VBox fx:id="dynamicContentContainer" spacing="30.0" style="-fx-padding: 30px 40px; -fx-background-color: #ffffff;">
                    <children>

                        <!-- OVERVIEW PANEL HEADER ROW -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="Employee Management System Gateway" />
                            </children>
                        </HBox>

                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 14px; -fx-text-fill: #4a5568;" text="Select a management task from the modules below or use the sidebar navigation controls to interact with system records." />

                        <!-- MODULE PORTAL GATEWAY BOXES -->
                        <HBox alignment="CENTER" spacing="30.0" style="-fx-padding: 10px 0;">
                            <children>

                                <!-- PORTAL OPTION 1: LINK TO DIRECTORY LIST -->
                                <VBox fx:id="btnGatewayViewList" alignment="CENTER" prefHeight="200.0" prefWidth="240.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-border-color: #e2e8f0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-cursor: hand; -fx-padding: 20px;">
                                    <children>
                                        <Label style="-fx-font-size: 40px;" text="📋" />
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="View Employee Directory" />
                                        <Label alignment="CENTER" style="-fx-font-family: 'Arial'; -fx-font-size: 12px; -fx-text-fill: #718096;" text="Browse active personnel logs, filtered departments, and edit core staffing configurations." textAlignment="CENTER" wrapText="true" />
                                    </children>
                                </VBox>

                                <!-- PORTAL OPTION 2: LINK TO REGISTRATION FORM -->
                                <VBox fx:id="btnGatewayAddEmployee" alignment="CENTER" prefHeight="200.0" prefWidth="240.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-border-color: #e2e8f0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-cursor: hand; -fx-padding: 20px;">
                                    <children>
                                        <Label style="-fx-font-size: 40px;" text="➕" />
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="Add New Profile" />
                                        <Label alignment="CENTER" style="-fx-font-family: 'Arial'; -fx-font-size: 12px; -fx-text-fill: #718096;" text="Register fresh personnel credentials, positions, assign shift tags, and structural details." textAlignment="CENTER" wrapText="true" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>