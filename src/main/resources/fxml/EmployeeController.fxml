<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="employeeMasterStructure" prefHeight="720.0" prefWidth="1180.0" style="-fx-background-color: #1E1B18;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EmployeeController">
    <left>
        <VBox fx:id="sidebarNavigationContainer" prefWidth="240.0" styleClass="sidebar-dark" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 0 0 36px 0;">
                    <children>
                        <ImageView fitHeight="56.0" fitWidth="56.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../images/pup_logo.png" /></image>
                        </ImageView>
                        <Label text="PUP SRC" style="-fx-text-fill: #D4A853; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 4px 16px; -fx-background-color: rgba(212,168,83,0.12); -fx-background-radius: 8px;" />
                    </children>
                </VBox>
                <VBox spacing="4.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 14px;">
                    <children>
                        <Label text="MAIN MENU" style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 8px 8px 8px;" />
                        <Button fx:id="btnSidebarDashboard" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Dashboard" styleClass="nav-item" />
                        <Button fx:id="btnSidebarMonitoring" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Monitoring" styleClass="nav-item" />
                        <Button fx:id="btnSidebarEmployees" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Employees" styleClass="nav-item nav-active" />
                        <Button fx:id="btnSidebarReports" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Reports" styleClass="nav-item" />
                        <Button fx:id="btnSidebarLogReturn" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Log Return" styleClass="nav-item" />
                        <Button fx:id="btnSidebarUsers" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Users" styleClass="nav-item" />
                        <Button fx:id="btnSidebarPasswordReset" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Reset Requests" styleClass="nav-item" />
                        <Label text="ACCOUNT" style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 16px 8px 8px 8px;" />
                        <Button fx:id="btnLogout" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Logout" styleClass="nav-item" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" style="-fx-padding: 16px;">
                    <Label text="2026 PUP — SRC" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 10px;" />
                </VBox>
            </children>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="62.0" styleClass="header-clean" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label text="Employee Management" styleClass="pg-title" />
                        <Label text="Select a management task below" styleClass="pg-sub" />
                    </children>
                </VBox>
                <StackPane HBox.hgrow="ALWAYS" />
                <HBox spacing="12.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" text="&#x1F514;" prefHeight="38.0" prefWidth="38.0" styleClass="icon-circle" />
                        <Button fx:id="btnHamburgerMenuToggle" mnemonicParsing="false" text="&#x2699;" prefHeight="38.0" prefWidth="38.0" styleClass="icon-circle" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #1E1B18; -fx-background-color: #1E1B18; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <VBox fx:id="dynamicContentContainer" spacing="24.0" style="-fx-padding: 28px 36px;">
                    <children>
                        <HBox alignment="CENTER" spacing="22.0" style="-fx-padding: 8px 0;">
                            <children>
                                <VBox fx:id="btnGatewayViewList" alignment="CENTER" prefHeight="220.0" prefWidth="260.0" spacing="16.0" styleClass="stat-dark" style="-fx-cursor: hand; -fx-padding: 28px;">
                                    <children>
                                        <Label text="&#x1F4CB;" style="-fx-font-size: 44px;" />
                                        <Label text="Employee Directory" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                                        <Label alignment="CENTER" text="Browse and manage personnel records." textAlignment="CENTER" wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.55);" />
                                    </children>
                                </VBox>
                                <VBox fx:id="btnGatewayAddEmployee" alignment="CENTER" prefHeight="220.0" prefWidth="260.0" spacing="16.0" styleClass="card" style="-fx-cursor: hand; -fx-padding: 28px;">
                                    <children>
                                        <Label text="&#x2795;" style="-fx-font-size: 44px;" />
                                        <Label text="Add New Employee" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FCA5A5;" />
                                        <Label alignment="CENTER" text="Register new personnel profiles." textAlignment="CENTER" wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #A8A29E;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
