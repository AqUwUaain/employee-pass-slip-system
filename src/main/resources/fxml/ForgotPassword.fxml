<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0.0" prefWidth="420.0" styleClass="modal-box" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ForgotPasswordController">
    <children>
        <VBox alignment="CENTER_LEFT" spacing="4.0" styleClass="modal-top" style="-fx-padding: 20px 28px;">
            <children>
                <Label text="Password Reset Request" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px; -fx-font-weight: bold;" />
                <Label text="We'll send you a link to reset your password" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;" />
            </children>
        </VBox>
        <VBox spacing="16.0" style="-fx-padding: 24px 28px; -fx-background-color: #2D2520;">
            <children>
                <Label text="Enter your registered email address:" style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;" />
                <TextField fx:id="resetEmailField" promptText="name@pup.edu.ph" styleClass="text-field" prefWidth="364.0" />
                <Label text="If your request was already approved, sign in using your account to complete the password reset. Do not submit multiple requests." style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11px; -fx-wrap-text: true;" maxWidth="364" />
                <Label fx:id="resetMessageLabel" text="" style="-fx-font-size: 12px;" />
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="cancelBtn" text="Cancel" styleClass="btn-neutral" />
                        <Button fx:id="submitBtn" text="Submit Request" styleClass="btn-gold" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
