<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="400.0" styleClass="modal-box logout-dialog" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ForgotPasswordController">
    <children>
        <Label text="Password Reset Request" styleClass="dialog-title" VBox.vgrow="NEVER" />
        <Label text="Enter your registered email address:" styleClass="dialog-subtitle" VBox.vgrow="NEVER" />
        <TextField fx:id="resetEmailField" promptText="name@pup.edu.ph" styleClass="text-field" prefWidth="320.0" VBox.vgrow="NEVER" />
        <Label text="If your request was already approved, sign in using your account to complete the password reset. Do not submit multiple requests." style="-fx-text-fill: #78716C; -fx-font-size: 11px; -fx-wrap-text: true; -fx-padding: 0 4px;" VBox.vgrow="NEVER" maxWidth="320" />
        <Label fx:id="resetMessageLabel" text="" style="-fx-font-size: 12px;" VBox.vgrow="NEVER" />
        <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="NEVER">
            <children>
                <Button fx:id="cancelBtn" text="Cancel" styleClass="btn-neutral" />
                <Button fx:id="submitBtn" text="Submit Request" styleClass="btn-gold" />
            </children>
        </HBox>
    </children>
</VBox>
