<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="reportsMasterStructure" prefHeight="720.0" prefWidth="1180.0" styleClass="page-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReportsController">
    <left>
        <VBox fx:id="sidebarNavigationContainer" prefWidth="240.0" styleClass="sidebar-dark" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 0 0 36px 0;">
                    <children>
                        <ImageView fitHeight="56.0" fitWidth="56.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../images/pup_logo.png" /></image>
                        </ImageView>
                        <Label text="PUP SRC" styleClass="sidebar-badge" />
                    </children>
                </VBox>
                <VBox spacing="4.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 14px;">
                    <children>
                        <Label text="MAIN MENU" style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 8px 8px 8px;" />
                        <Button fx:id="btnSidebarDashboard" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Dashboard" styleClass="nav-item" />
                        <Button fx:id="btnSidebarMonitoring" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Monitoring" styleClass="nav-item" />
                        <Button fx:id="btnSidebarEmployees" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Employees" styleClass="nav-item" />
                        <Button fx:id="btnSidebarReports" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Reports" styleClass="nav-item nav-active" />
                        <Button fx:id="btnSidebarLogReturn" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Log Return" styleClass="nav-item" />
                        <Button fx:id="btnSidebarUsers" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Users" styleClass="nav-item" />
                        <Button fx:id="btnSidebarPasswordReset" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Reset Requests" styleClass="nav-item" />
                        <Label text="ACCOUNT" style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 16px 8px 8px 8px;" />
                        <Button fx:id="btnLogout" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Logout" styleClass="nav-item" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" style="-fx-padding: 16px;">
                    <Label text="2026 PUP — SRC" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 10px;" />
                </VBox>
            </children>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="62.0" styleClass="header-clean" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label text="Reports" styleClass="pg-title" />
                        <Label text="Pass slip issuance analytics and history" styleClass="pg-sub" />
                    </children>
                </VBox>
                <StackPane HBox.hgrow="ALWAYS" />
                <HBox spacing="12.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnExportCsv" mnemonicParsing="false" text="&#x1F4E5; Export CSV" styleClass="btn-gold" />
                        <Button fx:id="btnOpenDashboard" mnemonicParsing="false" text="&#x1F3E0; Dashboard" styleClass="btn-maroon" />
                        <Button fx:id="btnOpenEmployees" mnemonicParsing="false" text="&#x1F465; Employees" styleClass="btn-maroon" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll-pane" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="24.0" style="-fx-padding: 28px 36px;">
                    <children>
                        <!-- Stats row -->
                        <HBox alignment="CENTER" spacing="18.0">
                            <children>
                                <!-- Total Employees -->
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="250.0" styleClass="stat-dark">
                                    <children>
                                        <VBox alignment="CENTER_LEFT" styleClass="stat-header" prefWidth="250.0">
                                            <children><Label text="TOTAL EMPLOYEES" styleClass="stat-header-label" /></children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="4.0" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblTotalEmployees" text="0" styleClass="stat-value" />
                                            </children>
                                            <padding><Insets bottom="10.0" /></padding>
                                        </VBox>
                                    </children>
                                </VBox>
                                <!-- Total Pass Slips -->
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="250.0" styleClass="stat-dark">
                                    <children>
                                        <VBox alignment="CENTER_LEFT" styleClass="stat-header" prefWidth="250.0">
                                            <children><Label text="TOTAL PASS SLIPS" styleClass="stat-header-label" /></children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="4.0" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblTotalPassSlips" text="0" styleClass="stat-value" />
                                            </children>
                                            <padding><Insets bottom="10.0" /></padding>
                                        </VBox>
                                    </children>
                                </VBox>
                                <!-- Current Month -->
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="250.0" styleClass="stat-light">
                                    <children>
                                        <VBox alignment="CENTER_LEFT" styleClass="stat-header" prefWidth="250.0">
                                            <children><Label text="THIS MONTH" styleClass="stat-header-label" /></children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="4.0" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblMonthlyCount" text="0" styleClass="stat-value" />
                                            </children>
                                            <padding><Insets bottom="10.0" /></padding>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <!-- Recent History -->
                        <VBox spacing="12.0" styleClass="card" style="-fx-padding: 22px;">
                            <children>
                                <Label text="Pass Slip Issuance Recent History" styleClass="sec-title" />
                                <VBox fx:id="recentHistoryList" spacing="8.0" style="-fx-background-color: #2D2520; -fx-background-radius: 12px; -fx-padding: 6px;">
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
