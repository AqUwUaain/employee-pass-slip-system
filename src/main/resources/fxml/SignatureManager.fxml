<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="signatureManagerRoot" prefHeight="720.0" prefWidth="1180.0" styleClass="page-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SignatureController">
    <left>
        <VBox fx:id="sidebarNavigationContainer" prefWidth="240.0" styleClass="sidebar-dark" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 0 0 36px 0;">
                    <children>
                        <ImageView fitHeight="56.0" fitWidth="56.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../images/pup_logo.png" /></image>
                        </ImageView>
                        <Label text="PUP SRC" styleClass="sidebar-badge" />
                    </children>
                </VBox>
                <VBox spacing="4.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 14px;">
                    <children>
                        <Label text="MAIN MENU" styleClass="sidebar-section-label" />
                        <Button fx:id="btnSidebarDashboard" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Dashboard" styleClass="nav-item" />
                        <Button fx:id="btnSidebarMonitoring" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   System Logs" styleClass="nav-item" />
                        <Button fx:id="btnManageEmployees" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Manage Employees  ▾" styleClass="nav-item" />
                        <VBox fx:id="manageEmployeesSubMenu" styleClass="nav-sub-menu" managed="false" visible="false">
                            <children>
                                <Button fx:id="btnSidebarEmployeeDirectory" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Employee Directory" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarAddEmployee" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Add New Employee" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarImportEmployee" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Import Employees" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarReports" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Reports" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarLogReturn" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Log Return &amp; Monitoring" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarUsers" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Users" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarSignatures" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Signatures" styleClass="nav-sub-item nav-sub-active" />
                            </children>
                        </VBox>
                        <Button fx:id="btnSidebarPasswordReset" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Reset Requests" styleClass="nav-item" />
                        <Label text="ACCOUNT" style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 16px 8px 8px 8px;" />
                        <Button fx:id="btnLogout" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Logout" styleClass="nav-item" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" style="-fx-padding: 16px;">
                    <Label text="2026 PUP — SRC" styleClass="sidebar-footer-label" />
                </VBox>
            </children>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="62.0" styleClass="header-clean" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label text="Signature Management" styleClass="pg-title" />
                        <Label text="Upload and manage your digital signature for pass slip approval" styleClass="pg-sub" />
                    </children>
                </VBox>
                <StackPane HBox.hgrow="ALWAYS" />
                <HBox spacing="12.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnThemeToggle" mnemonicParsing="false" text="☀" prefHeight="38.0" prefWidth="38.0" styleClass="icon-circle" />
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" text="&#x1F514;" prefHeight="38.0" prefWidth="38.0" styleClass="icon-circle" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll-pane" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="22.0" style="-fx-padding: 28px 36px;">
                    <children>
                        <!-- Info banner -->
                        <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: rgba(212,168,83,0.1); -fx-border-color: #D4A853; -fx-border-width: 1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 10px 14px;">
                            <children>
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #D4A853;" text="&#x2139;" />
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #D4A853; -fx-wrap-text: true;" text="Your signature will be automatically applied to all pass slips you issue. Only one signature is allowed per account." HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <!-- Signature card -->
                        <HBox spacing="22.0" VBox.vgrow="ALWAYS">
                            <children>
                                <!-- Upload section -->
                                <VBox spacing="14.0" styleClass="card" style="-fx-padding: 24px;" prefWidth="380.0">
                                    <children>
                                        <Label text="Your Signature" styleClass="sec-title" />
                                        <Label fx:id="lblSignatureStatus" text="No signature uploaded" style="-fx-text-fill: #A8A29E;" />
                                        <VBox alignment="CENTER" prefHeight="200.0" style="-fx-border-color: #3D3229; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-color: #FFFFFF; -fx-background-radius: 8px;">
                                            <children>
                                                <ImageView fx:id="imgSignaturePreview" fitHeight="180.0" fitWidth="340.0" preserveRatio="true" />
                                            </children>
                                            <VBox.margin>
                                                <Insets top="8.0" />
                                            </VBox.margin>
                                        </VBox>
                                        <Label fx:id="lblSignatureName" text="No signature uploaded" style="-fx-text-fill: #78716C; -fx-font-size: 11px;" />
                                        <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 8px 0 0 0;">
                                            <children>
                                                <Button fx:id="btnUploadSignature" mnemonicParsing="false" prefHeight="38.0" text="&#x1F4C1; Upload Signature" styleClass="btn-gold" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                            </children>
                                        </HBox>
                                        <Button fx:id="btnRemoveSignature" mnemonicParsing="false" prefHeight="36.0" text="&#x274C; Remove Signature" styleClass="btn-danger" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <!-- Info section -->
                                <VBox spacing="14.0" styleClass="card" style="-fx-padding: 24px;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="How It Works" styleClass="sec-title" />
                                        <VBox spacing="10.0" style="-fx-padding: 8px 0;">
                                            <children>
                                                <Label text="1. Upload a clear image of your signature (PNG, JPG)" style="-fx-text-fill: #A8A29E; -fx-font-size: 12px; -fx-wrap-text: true;" />
                                                <Label text="2. Your signature is stored securely in the database" style="-fx-text-fill: #A8A29E; -fx-font-size: 12px; -fx-wrap-text: true;" />
                                                <Label text="3. When you issue a pass slip, your signature is automatically embedded in the PDF" style="-fx-text-fill: #A8A29E; -fx-font-size: 12px; -fx-wrap-text: true;" />
                                                <Label text="4. Only one signature is allowed per admin account" style="-fx-text-fill: #A8A29E; -fx-font-size: 12px; -fx-wrap-text: true;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" style="-fx-padding: 12px 0 0 0; -fx-border-color: transparent transparent #3D3229 transparent; -fx-border-width: 0 0 1px 0;">
                                            <children>
                                                <Label text="RECOMMENDED:" style="-fx-text-fill: #D4A853; -fx-font-size: 11px; -fx-font-weight: bold;" />
                                                <Label text="- Use a white or transparent background" style="-fx-text-fill: #78716C; -fx-font-size: 11px;" />
                                                <Label text="- Keep the image clear and readable" style="-fx-text-fill: #78716C; -fx-font-size: 11px;" />
                                                <Label text="- Preferred size: 300x100 pixels" style="-fx-text-fill: #78716C; -fx-font-size: 11px;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
