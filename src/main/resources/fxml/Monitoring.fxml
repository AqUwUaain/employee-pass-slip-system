<?xml version="1.0" encoding="UTF-8"?>

<!--
    System Module: Real-Time Attendance & Access Monitoring
    View Reference: Monitoring.fxml
    Target Design Guide Compatibility: Dashboard.fxml Identity System
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="monitoringMasterStructure" prefHeight="720.0" prefWidth="1150.0" style="-fx-background-color: #ffffff;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MonitoringController">

    <!-- TOP BRAND HEADER BAR (Matches Dashboard.fxml exactly) -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="75.0" style="-fx-background-color: #ffffff; -fx-border-color: #800000 transparent #800000 transparent; -fx-border-width: 4px 0 1px 0; -fx-padding: 0 25px 0 15px;" BorderPane.alignment="CENTER">
            <children>
                <!-- PUP Institutional Logo -->
                <ImageView fitHeight="55.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                </ImageView>

                <!-- Branding Text Stack -->
                <VBox alignment="CENTER_LEFT" spacing="2.0">
                    <children>
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Polytechnic University of the Philippines" />
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 17px; -fx-font-style: italic; -fx-text-fill: #333333;" text="Santa Rosa Campus" />
                    </children>
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </VBox>

                <StackPane HBox.hgrow="ALWAYS" />

                <!-- Utility Notification and Menu Controls -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="🔔" prefHeight="35.0" prefWidth="35.0" />
                        <Button fx:id="btnHamburgerMenuToggle" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 4px; -fx-cursor: hand;" text="☰" prefHeight="35.0" prefWidth="35.0" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <!-- LEFT REGISTRY NAVIGATION SIDEBAR PANEL (Matches Dashboard.fxml exactly) -->
    <left>
        <VBox fx:id="sidebarNavigationContainer" prefWidth="240.0" style="-fx-background-color: #800000; -fx-padding: 25px 0 15px 0;" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <!-- Large Main Round Logo Frame -->
                <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/pup_logo.png" />
                    </image>
                    <VBox.margin>
                        <Insets bottom="40.0" />
                    </VBox.margin>
                </ImageView>

                <!-- Navigation Control Item Switches -->
                <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 12px;">
                    <children>
                        <Button fx:id="btnSidebarDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Dashboard" />
                        <Button fx:id="btnSidebarMonitoring" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Monitoring and Logs" />
                        <Button fx:id="btnSidebarEmployees" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Employee Management" />
                        <Button fx:id="btnSidebarReports" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-padding: 12px 15px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Report Generation &amp; History" />
                    </children>
                </VBox>

                <!-- Structural Sidebar Brand Footer Signature -->
                <Label style="-fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-opacity: 0.85;" text="2026 PUP - SRC" />
            </children>
        </VBox>
    </left>

    <!-- MAIN TELEMETRY CONTENT WORKSPACE REGION -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #ffffff; -fx-background-color: #ffffff; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="25.0" style="-fx-padding: 30px 40px; -fx-background-color: #ffffff;">
                    <children>

                        <!-- LIVE STATUS METRIC CARDS ROW -->
                        <HBox alignment="CENTER" spacing="25.0">
                            <children>

                                <!-- CARD 1: STREAM GATEWAY STATUS -->
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="240.0" style="-fx-background-color: #800000; -fx-background-radius: 14px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffe600; -fx-background-radius: 14px 14px 0 0; -fx-padding: 6px 15px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #800000; -fx-font-size: 11px;" text="📡 SCANNER STATUS" />
                                            </children>
                                        </HBox>
                                        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblScannerStatus" style="-fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 26px; -fx-font-weight: bold;" text="ONLINE" />
                                                <Label style="-fx-text-fill: #ffe600; -fx-font-family: 'Arial'; -fx-font-size: 12px;" text="Gate Terminal Alpha" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- CARD 2: TODAY'S UNIQUE RUNNING COUNTS -->
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="240.0" style="-fx-background-color: #800000; -fx-background-radius: 14px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffe600; -fx-background-radius: 14px 14px 0 0; -fx-padding: 6px 15px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #800000; -fx-font-size: 11px;" text="⏳ TOTAL IN-CAMPUS" />
                                            </children>
                                        </HBox>
                                        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblTotalInCampusCount" style="-fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 38px; -fx-font-weight: bold;" text="142" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- CARD 3: RECENT ALERTS/FLAG TRIPS -->
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="240.0" style="-fx-background-color: #800000; -fx-background-radius: 14px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffe600; -fx-background-radius: 14px 14px 0 0; -fx-padding: 6px 15px;">
                                            <children>
                                                <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #800000; -fx-font-size: 11px;" text="⚠️ UNRESOLVED PASS SLIPS" />
                                            </children>
                                        </HBox>
                                        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblActiveAlertsCount" style="-fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 38px; -fx-font-weight: bold;" text="3" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <!-- LIVE FEED DATA UTILITY BAR -->
                        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 12px 20px; -fx-background-radius: 8px; -fx-border-color: #edf2f7; -fx-border-width: 1px; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 1);">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-weight: bold; -fx-text-fill: #4a5568; -fx-font-size: 11px;" text="Filter Live Dynamic Workspace Feed" />
                                        <TextField fx:id="txtSearchMonitoringLogs" promptText="Enter profile identification keyword or location tag..." style="-fx-font-size: 13px; -fx-padding: 8px 12px; -fx-background-color: #ffffff; -fx-border-color: #cbd5e0; -fx-border-radius: 4px;" />
                                    </children>
                                </VBox>
                                <VBox alignment="BOTTOM_CENTER">
                                    <children>
                                        <Button fx:id="btnRefreshMonitoringFeed" mnemonicParsing="false" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8px 18px; -fx-background-radius: 4px; -fx-cursor: hand;" text="🔄 Force Refresh" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- MAIN REAL-TIME ATTENDANCE LOG DATA GRID CONTAINER -->
                        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="🕒 REAL-TIME ENTRY &amp; EXIT ACCESS STREAM" />
                                    </children>
                                </HBox>

                                <!-- Main Monitoring Data Frame Table View Component -->
                                <TableView fx:id="monitoringTableView" prefHeight="300.0" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1px;" styleClass="monitoring-data-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colTimestamp" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Timestamp" />
                                        <TableColumn fx:id="colEmployeeID" prefWidth="180.0" style="-fx-alignment: CENTER;" text="Employee ID" />
                                        <TableColumn fx:id="colFullName" prefWidth="250.0" style="-fx-alignment: CENTER_LEFT;" text="Personnel Name" />
                                        <TableColumn fx:id="colDepartment" prefWidth="180.0" style="-fx-alignment: CENTER;" text="Department" />
                                        <TableColumn fx:id="colAccessType" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Access Type" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>