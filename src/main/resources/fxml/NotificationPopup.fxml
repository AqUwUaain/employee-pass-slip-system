<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="notificationPopup" prefWidth="360.0" maxHeight="500.0" style="-fx-background-color: #252220; -fx-background-radius: 16px; -fx-border-color: #3D3229; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 30, 0, 0, 8);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.NotificationPopupController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 0 0 12 0;">
            <children>
                <Label text="&#x1F514;" style="-fx-font-size: 16px;" />
                <Label fx:id="lblNotificationTitle" text="Notifications" style="-fx-text-fill: #F5F5F4; -fx-font-size: 15px; -fx-font-weight: bold;" />
            </children>
        </HBox>
        <ScrollPane fitToWidth="true" maxHeight="400.0" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <content>
                <VBox fx:id="vboxNotifications" spacing="4.0" style="-fx-background-color: transparent;">
                </VBox>
            </content>
        </ScrollPane>
        <HBox alignment="CENTER" style="-fx-padding: 12 0 0 0;">
            <children>
                <Button fx:id="btnViewAllNotifications" text="View All Activities →" style="-fx-background-color: rgba(212,168,83,0.12); -fx-text-fill: #D4A853; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-padding: 8px 16px; -fx-cursor: hand;" />
            </children>
        </HBox>
    </children>
</VBox>
