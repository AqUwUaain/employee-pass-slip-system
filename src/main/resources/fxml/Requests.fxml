<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="720.0" prefWidth="1180.0" styleClass="page-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.RequestsController">
    <left>
        <VBox prefWidth="240.0" styleClass="sidebar-dark" alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 0 0 36px 0;">
                    <children>
                        <ImageView fitHeight="56.0" fitWidth="56.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../images/pup_logo.png" /></image>
                        </ImageView>
                        <Label text="PUP SRC" styleClass="sidebar-badge" />
                    </children>
                </VBox>
                <VBox spacing="4.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 14px;">
                    <children>
                        <Label text="MAIN MENU" styleClass="sidebar-section-label" />
                        <Button fx:id="btnSidebarDashboard" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Dashboard" styleClass="nav-item" />
                        <Button fx:id="btnSidebarMonitoring" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   System Logs" styleClass="nav-item" />
                        <Button fx:id="btnSidebarLogReturn" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Log Return &amp; Monitoring" styleClass="nav-item" />
                        <Button fx:id="btnManageEmployees" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Manage Employees  ▾" styleClass="nav-item" />
                        <VBox fx:id="manageEmployeesSubMenu" styleClass="nav-sub-menu" managed="false" visible="false">
                            <children>
                                <Button fx:id="btnSidebarEmployeeDirectory" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Employee Directory" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarAddEmployee" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Add New Employee" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarImportEmployee" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Import Employees" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarReports" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Reports" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarUsers" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Users" styleClass="nav-sub-item" />
                                <Button fx:id="btnSidebarSignatures" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x251C;   Signatures" styleClass="nav-sub-item" />
                            </children>
                        </VBox>
                        <Button fx:id="btnSidebarRequests" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Requests" styleClass="nav-item nav-active" />
                        <Label text="ACCOUNT" styleClass="sidebar-section-label" />
                        <Button fx:id="btnLogout" alignment="CENTER_LEFT" maxWidth="Infinity" mnemonicParsing="false" text="&#x25A0;   Logout" styleClass="nav-item" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" style="-fx-padding: 16px;">
                    <Label text="2026 PUP — SRC" styleClass="sidebar-footer-label" />
                </VBox>
            </children>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="62.0" styleClass="header-clean" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label text="Requests" styleClass="pg-title" />
                        <Label text="Review and manage all pending requests" styleClass="pg-sub" />
                    </children>
                </VBox>
                <StackPane HBox.hgrow="ALWAYS" />
                <HBox spacing="12.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnThemeToggle" mnemonicParsing="false" text="☀" prefHeight="38.0" prefWidth="38.0" styleClass="icon-circle" />
                        <Button fx:id="btnNotificationsAlert" mnemonicParsing="false" text="&#x1F514;" prefHeight="38.0" prefWidth="38.0" styleClass="icon-circle" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="content-scroll-pane" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="16.0" style="-fx-padding: 28px 36px 40px 36px;">
                    <children>
                        <!-- Summary -->
                        <HBox spacing="16.0" alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="2.0" styleClass="card" style="-fx-padding: 12px 20px;">
                                    <children>
                                        <Label text="TOTAL PENDING" style="-fx-text-fill: #FBBF24; -fx-font-size: 10px; -fx-font-weight: bold;" />
                                        <Label fx:id="lblTotalPending" text="0" style="-fx-text-fill: #F5F5F4; -fx-font-size: 24px; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Category filters -->
                        <HBox fx:id="filterBox" spacing="16.0" alignment="CENTER_LEFT" />

                        <!-- Main content: table + preview -->
                        <HBox spacing="16.0" VBox.vgrow="ALWAYS" minHeight="300.0">
                            <children>
                                <!-- Table -->
                                <VBox spacing="10.0" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
                                    <children>
                                        <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS" prefHeight="250.0">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                                <TableColumn fx:id="colCategory" prefWidth="110.0" text="Category" />
                                                <TableColumn fx:id="colRequester" prefWidth="150.0" text="Requester" />
                                                <TableColumn fx:id="colDetail" prefWidth="180.0" text="Detail" />
                                                <TableColumn fx:id="colRequestedAt" prefWidth="150.0" text="Date" />
                                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                                            </columns>
                                        </TableView>
                                        <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 4px 0 0 0;">
                                            <children>
                                                <Button fx:id="btnApprove" text="Approve" disable="true" style="-fx-background-color: rgba(5,150,105,0.15); -fx-text-fill: #34D399; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 12px; -fx-padding: 10px 20px; -fx-border-color: rgba(5,150,105,0.25); -fx-border-width: 1px; -fx-cursor: hand;" />
                                                <Button fx:id="btnReject" text="Reject" disable="true" style="-fx-background-color: rgba(220,38,38,0.12); -fx-text-fill: #FCA5A5; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 12px; -fx-padding: 10px 20px; -fx-border-color: rgba(220,38,38,0.25); -fx-border-width: 1px; -fx-cursor: hand;" />
                                                <HBox HBox.hgrow="ALWAYS" />
                                                <Label fx:id="messageLabel" text="" style="-fx-font-size: 12px;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- Preview -->
                                <VBox fx:id="previewPane" spacing="12.0" prefWidth="400.0" maxWidth="400.0" styleClass="card" style="-fx-padding: 24px;" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblPreviewTitle" text="Select a request" styleClass="sec-title" />
                                        <Label fx:id="lblPreviewRequester" text="" style="-fx-text-fill: #D6D3D1; -fx-font-size: 13px;" />
                                        <Label fx:id="lblPreviewDetail" text="" style="-fx-text-fill: #A8A29E; -fx-font-size: 13px;" />
                                        <Label fx:id="lblPreviewDetail2" text="" style="-fx-text-fill: #A8A29E; -fx-font-size: 13px;" />
                                        <Label fx:id="lblPreviewDetail3" text="" visible="false" managed="false" style="-fx-text-fill: #A8A29E; -fx-font-size: 13px; -fx-wrap-text: true;" />
                                        <Label fx:id="lblPreviewStatus" text="" style="-fx-font-size: 14px;" />

                                        <!-- Pass Slip details -->
                                        <VBox fx:id="vboxPassSlipPreview" visible="false" managed="false" spacing="6.0" style="-fx-padding: 8px 0;">
                                            <children>
                                                <Label text="Pass slip details are shown in the table." style="-fx-text-fill: #78716C; -fx-font-size: 11px;" />
                                            </children>
                                        </VBox>

                                        <!-- Signature preview -->
                                        <VBox fx:id="vboxSignaturePreview" visible="false" managed="false" spacing="6.0">
                                            <children>
                                                <Label text="Signature Preview" style="-fx-text-fill: #D4A853; -fx-font-size: 11px; -fx-font-weight: bold;" />
                                                <VBox alignment="CENTER" prefHeight="160.0" VBox.vgrow="ALWAYS" style="-fx-border-color: #3D3229; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-color: #FFFFFF; -fx-background-radius: 8px;">
                                                    <children>
                                                        <ImageView fx:id="imgPreviewSignature" fitHeight="140.0" fitWidth="340.0" preserveRatio="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
