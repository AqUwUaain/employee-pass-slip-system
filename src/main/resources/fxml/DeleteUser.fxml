<?xml version="1.0" encoding="UTF-8"?>

<!--
    System Module: Administrative Access Control
    View Reference: DeleteUser.fxml Pop-up Modal Window
    Target Design Guide Compatibility: Dashboard.fxml Identity System
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="deleteUserModalRoot" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="450.0" spacing="0.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-border-color: #800000; -fx-border-radius: 12px; -fx-border-width: 2px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 5);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DeleteUserController">
    <children>

        <!-- MODAL HEADER BAR (Matches Dashboard Core Palette Archetype) -->
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #800000; -fx-background-radius: 9px 9px 0 0; -fx-padding: 0 20px;">
            <children>
                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffe600;" text="⚠️ Confirm Access Revocation" />
            </children>
        </HBox>

        <!-- CONTENT WORKING SPACE AREA -->
        <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 30px 25px;">
            <children>

                <!-- Graphic Structural Icon Element Placeholder -->
                <Label style="-fx-font-size: 42px;" text="🚫" />

                <!-- Context Context Identity Stacks -->
                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Label style="-fx-font-family: 'Arial'; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Delete System User Credentials?" textAlignment="CENTER" />
                        <Label fx:id="lblWarningUsername" style="-fx-font-family: 'Arial'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #800000;" text="[Username / Access ID Placeholder]" textAlignment="CENTER" />
                    </children>
                </VBox>

                <!-- Structural Notification Advisory Content Paragraph -->
                <Label style="-fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-text-fill: #555555; -fx-line-spacing: 3px;" text="Warning: Purging this user profile immediately completely destroys terminal access privileges, removes active active security certificates, and restricts them from logging back into the monitoring system database." textAlignment="CENTER" wrapText="true" />

                <!-- ACTION BUTTON CONTROLS OVERLAY ROW -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>

                        <!-- Abort Operation Control Switch -->
                        <Button fx:id="btnCancelUserDelete" mnemonicParsing="false" prefHeight="38.0" prefWidth="130.0" style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;" text="No, Keep User" />

                        <!-- Execute Safe Mutative Purge Data Request Switch -->
                        <Button fx:id="btnConfirmUserDelete" mnemonicParsing="false" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #800000; -fx-text-fill: #ffffff; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(128,0,0,0.2), 5, 0, 0, 2);" text="Yes, Delete User" />

                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>

            </children>
        </VBox>

    </children>
</VBox>